{
  "manifest_version": 3,
  "name": "Password Generator M01",
  "version": "1.0.0",
  "description": "A clean, secure password generator with strength analysis. No data collected, no tracking, no ads.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Password Generator M01",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": []
}